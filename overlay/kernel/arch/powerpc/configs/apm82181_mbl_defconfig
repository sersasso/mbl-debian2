CONFIG_PPC32=y
CONFIG_44x=y
CONFIG_464_CPU=y
CONFIG_APM821xx=y
CONFIG_CPU_BIG_ENDIAN=y
CONFIG_MMU=y
CONFIG_NOT_COHERENT_CACHE=y
CONFIG_NR_CPUS=1
CONFIG_TINY_RCU=y

# Memory & paging
CONFIG_PPC_4K_PAGES=y
CONFIG_FLATMEM=y
CONFIG_HIGHMEM=n

# Boot options
CONFIG_CMDLINE="root=/dev/sda2 rootfstype=ext4 console=ttyS0,115200"
CONFIG_CMDLINE_FROM_BOOTLOADER=y
CONFIG_BLK_DEV_INITRD=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_MSDOS_PARTITION=y
CONFIG_EFI_PARTITION=y

# Networking essentials
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_NETFILTER_ADVANCED=n
CONFIG_BRIDGE=n
CONFIG_VLAN_8021Q=n

# Ethernet driver (MyBook Live uses APM82181 integrated GbE)
CONFIG_NET_VENDOR_AMAZON=n
CONFIG_NET_VENDOR_MARVELL=n
CONFIG_NET_VENDOR_REALTEK=n
CONFIG_NET_VENDOR_INTEL=n
CONFIG_NET_VENDOR_BROADCOM=n
CONFIG_NET_VENDOR_MICREL=n
CONFIG_NET_VENDOR_MICROCHIP=n
CONFIG_NET_VENDOR_NATSEMI=n
CONFIG_NET_VENDOR_STMICRO=n
CONFIG_NET_VENDOR_XILINX=n

CONFIG_GIANFAR=y   # driver corretto per APM82181

# SATA / Storage
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_SATA_AHCI_PLATFORM=y
CONFIG_ATA_VERBOSE_ERROR=n

# USB (per recovery, storage esterni)
CONFIG_USB=n
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=n
CONFIG_USB_STORAGE=y

# Block layer
CONFIG_BLOCK=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI=y
CONFIG_SCSI_LOWLEVEL=n

# Thermal / Fan / GPIO / LEDs
CONFIG_HWMON=y
CONFIG_SENSORS_LM75=n
CONFIG_SENSORS_LM85=n
CONFIG_THERMAL=n
CONFIG_THERMAL_WRITABLE_TRIPS=n
CONFIG_GPIO_SYSFS=y
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_GPIO=y

# Device Tree
CONFIG_OF=y
CONFIG_OF_GPIO=y
CONFIG_OF_MDIO=y

# Kernel options
CONFIG_HZ_100=y
CONFIG_PREEMPT_NONE=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_PRINTK=y
CONFIG_BUG=y

# Modules
CONFIG_MODULES=n
CONFIG_MODULE_UNLOAD=y

# Crypto (necessario per ext4, ssh, https)
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_CRC32C=y

# Debug disabilitato
CONFIG_DEBUG_KERNEL=n
CONFIG_KALLSYMS=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_DEBUG_FS=n
